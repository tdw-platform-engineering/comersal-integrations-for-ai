{
  "name": "pedidos",
  "root": "lambdas/pedidos",
  "targets": {
    "lint": {
      "command": "uv run ruff check src/ tests/",
      "options": { "cwd": "lambdas/pedidos" }
    },
    "test": {
      "command": "uv run pytest tests/ -q",
      "options": { "cwd": "lambdas/pedidos" }
    },
    "build": {
      "command": "docker build -t comersal/integrations/pedidos:dev -f Dockerfile ../..",
      "options": { "cwd": "lambdas/pedidos" }
    }
  }
}
